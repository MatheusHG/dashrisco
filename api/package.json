{
  "name": "@jbd/api",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "dotenv -e .env -- ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:prod": "dotenv -e .env.production -- ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "node dist/server.js",
    "db:push": "prisma db push",
    "db:push:prod": "dotenv -e .env.production -- prisma db push",
    "db:seed": "ts-node src/prisma/seed.ts",
    "db:seed:prod": "dotenv -e .env.production -- ts-node src/prisma/seed.ts",
    "db:generate": "prisma generate",
    "deploy": "dotenv -e .env -- prisma db push && npm run build && npm run start",
    "deploy:prod": "npm run db:push:prod && npm run db:generate && npm run build && npm run start"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  },
  "dependencies": {
    "@clickhouse/client": "^1.18.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/jwt": "^9.0.1",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@prisma/client": "^6.6.0",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.2",
    "fastify": "^5.6.2",
    "otplib": "^12.0.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^24.10.1",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.6.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
